rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

// Users: Only access own data
match /users/{userId} {
allow read, write: if request.auth != null && request.auth.uid == userId;
allow create: if request.auth == null;
}

// Ads: Public read, admin write
match /ads/{adId} {
allow read: if true;
allow write: if request.auth != null &&
get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
}

// Plans: Public read
match /plans/{planId} {
allow read: if true;
allow write: if request.auth != null &&
get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
}

// Transactions: Own data only
match /transactions/{txId} {
allow read: if request.auth != null && resource.data.userId == request.auth.uid;
allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
}

// Withdrawals: Create own, admin update
match /withdrawals/{wdId} {
allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
allow read: if request.auth != null && resource.data.userId == request.auth.uid;
allow update: if request.auth != null &&
get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'support'];
}

// Referrals: Read own
match /referrals/{refId} {
allow read: if request.auth != null &&
(resource.data.referrerId == request.auth.uid || resource.data.referredId == request.auth.uid);
}
}
}